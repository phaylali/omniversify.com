---
import '../styles/Carousel.css';
---
<div class="carousel-container">
  <div class="carousel" id="carousel">
    <a href="/Apps" class="carousel__cell" style="background-color: red;">Apps</a>
    <a href="/Blog" class="carousel__cell" style="background-color: blue;">Blog</a>
    <a href="/Products" class="carousel__cell" style="background-color: green;">Products</a>
    <a href="/Multimedia" class="carousel__cell" style="background-color: yellow;">Multimedia</a>
    <a href="/Projects" class="carousel__cell" style="background-color: purple;">Projects</a>
    <a href="/Socials" class="carousel__cell" style="background-color: orange;">Socials</a>
    <a href="/About" class="carousel__cell" style="background-color: pink;">About</a>
  </div>
  <div class="carousel-label" id="carousel-label">Apps</div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.getElementById('carousel');
    const label = document.getElementById('carousel-label');
    let currentIndex = 0;
    const planets = 7;

    const updateLabel = () => {
      const cells = carousel!.querySelectorAll('.carousel__cell');
      label!.textContent = cells[currentIndex].textContent;
    };

    const rotateCarousel = () => {
      const angle = (currentIndex / planets) * -360;
      carousel!.style.transform = `translateZ(-30rem) rotateY(${angle}deg)`;
      updateLabel();
    };

    setInterval(() => {
      currentIndex = (currentIndex + 1) % planets;
      rotateCarousel();
    }, 3000);

    // Initial label update
    updateLabel();
  });
</script>
