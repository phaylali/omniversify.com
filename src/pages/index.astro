---
import Carousel from '../components/Carousel.astro';
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <div id="scroll-container" class="snap-y snap-mandatory h-screen overflow-hidden">
    <section class="h-screen flex items-center justify-center relative snap-start">
      <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/path-to-space-background.jpg');">
        <div class="bg-black bg-opacity-50 h-full w-full"></div>
      </div>
      <div class="relative z-10 text-center">
        <Carousel />
      </div>
    </section>
    <section class="h-screen flex items-center justify-center bg-gray-800 snap-start">
      <h2 class="text-4xl">Section 2</h2>
    </section>
    <section class="h-screen flex items-center justify-center bg-gray-700 snap-start">
      <h2 class="text-4xl">Section 3</h2>
    </section>
    <section class="h-screen flex items-center justify-center bg-gray-600 snap-start">
      <h2 class="text-4xl">Section 4</h2>
    </section>
    <section class="h-screen flex items-center justify-center bg-gray-500 snap-start">
      <h2 class="text-4xl">Section 5</h2>
    </section>
  </div>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const container = document.getElementById('scroll-container');
      let isScrolling = false;
      let currentSectionIndex = 0;

      const sections = Array.from(container!.children);

      const scrollToSection = (index: any) => {
        if (index < 0 || index >= sections.length) return;

        isScrolling = true;
        currentSectionIndex = index;

        const targetScrollTop = sections[index].scrollTop;

        container!.scrollTo({
          top: targetScrollTop,
          behavior: 'smooth'
        });

        setTimeout(() => {
          isScrolling = false;
        }, 1000); // Lock scrolling for 1 second to allow smooth transition
      };

      const handleWheel = (e: any) => {
        if (isScrolling) return;

        if (e.deltaY > 0) {
          scrollToSection(currentSectionIndex + 1);
        } else {
          scrollToSection(currentSectionIndex - 1);
        }
      };

      container!.addEventListener('wheel', (e) => {
        e.preventDefault();
        handleWheel(e);
      }, { passive: false });

      // Optionally handle touch events for mobile devices
      let touchStartY = 0;
      container!.addEventListener('touchstart', (e) => {
        touchStartY = e.touches[0].clientY;
      }, { passive: false });

      container!.addEventListener('touchmove', (e) => {
        e.preventDefault();
        const touchEndY = e.touches[0].clientY;
        const touchDeltaY = touchStartY - touchEndY;

        if (isScrolling) return;

        if (touchDeltaY > 50) {
          scrollToSection(currentSectionIndex + 1);
        } else if (touchDeltaY < -50) {
          scrollToSection(currentSectionIndex - 1);
        }
      }, { passive: false });
    });
  </script>
</Layout>
